# MongoDB 配置
MONGODB_URI=mongodb://127.0.0.1:27017/tap_system

# JWT 密钥
JWT_SECRET=change-me

# 服务器配置
PORT=3000
NODE_ENV=development

# ===== LINE 官方账号配置（@380xfno，泰国，未验证账号）=====
# Channel ID（公开，可提交）
LINE_CHANNEL_ID=2010752592
# 以下两项为密钥，从 LINE Developers Console 获取，禁止提交到 git
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# LINE OA ID（加好友链接用，如 @380xfno；不要与 LINE_CHANNEL_ID 混淆）
LINE_OA_ID=
# LIFF ID（预留方案B 官方 Account Link，本期可空）
LINE_LIFF_ID=
# 公网 Base URL（用于 Rich Menu / Flex 卡片拼接跳转地址，如 https://your-domain.com）
LINE_WEBHOOK_BASE_URL=
# 单一 LINE OA 归属公司 ObjectId（Webhook 无鉴权上下文时定位公司，缺省回退首个公司）
LINE_DEFAULT_COMPANY_ID=
